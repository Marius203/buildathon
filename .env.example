# Copy to .env at the repo root and fill values.
# All services (agent, backend) read from this single file.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MAIN_MODEL=qwen2.5:14b-instruct
OLLAMA_SMALL_MODEL=qwen2.5:3b-instruct
OLLAMA_EMBED_MODEL=bge-m3

# MongoDB
MONGODB_URI=PLACEHOLDER_MONGO_URI
MONGODB_DB=ec_assistant
MONGODB_DB_NAME=ec_chatbot

# Agent storage
CHROMA_PERSIST_DIR=./data/chroma

# Backend auth
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Uploadthing
UPLOADTHING_SECRET=PLACEHOLDER_UPLOADTHING_SECRET
UPLOADTHING_BUCKET_DOCS=documents
UPLOADTHING_BUCKET_IMAGES=photos
UPLOADTHING_APP_ID=PLACEHOLDER_UPLOADTHING_APP_ID

# External APIs
GOOGLE_MAPS_API_KEY=PLACEHOLDER_MAPS_KEY

# Claude (Anthropic) — used by the agent answerer in place of Ollama/qwen
CLAUDE_API_KEY=PLACEHOLDER_CLAUDE_KEY
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=1024
